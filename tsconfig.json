{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["jest", "node"]
  },
  "include": ["src", "tests", "__tests__", "jest.setup.renderer.ts", "playwright.config.ts"]
}
