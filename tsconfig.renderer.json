{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "rootDir": "src/renderer",
    "outDir": "dist/renderer",
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
